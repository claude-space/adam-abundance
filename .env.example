# SHA assigns the port at provisioning time — replace with what was given.
PORT=3000

# basePath for serving under Caddy strip_prefix routing.
#   Local dev: leave empty (you hit the app at http://localhost:PORT/)
#   Production: set to your agent's path, e.g. "/agents/my-dashboard"
# This is read by src/lib/bp.ts and prepended to internal <Link> + fetch() URLs.
NEXT_PUBLIC_BASE_PATH=

# Supabase — point at the agent's OWN Supabase project (not SHA's).
# Provisioning typically creates a dedicated Supabase project per agent;
# its URL + anon key go here.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Optional — only set if your queries need to bypass RLS. Service role
# bypasses ALL row-level security; use sparingly. NEVER expose it to
# the client (only use in server components / route handlers).
# SUPABASE_SERVICE_ROLE_KEY=
