# =============================================================================
# Switchboard — environment template (NON-SECRET placeholders)
#
# Real credentials live in `switchboard.env` (gitignored, LIVE production
# secrets). Switchboard loads that file by default; point SWITCHBOARD_ENV_FILE
# elsewhere to override. This template documents every variable the credentials
# layer (src/switchboard/credentials.py) and config (src/switchboard/config.py)
# know how to resolve. Copy to switchboard.env and fill in real values, or reuse
# the consolidated file already present.
# =============================================================================

# ---- Switchboard core / operational (non-secret) ----------------------------
SWITCHBOARD_ENV=local                     # local | staging | prod
SWITCHBOARD_ENV_FILE=switchboard.env      # where secrets are loaded from
SWITCHBOARD_PORT=8080
SWITCHBOARD_BRANDS=hotcars,carbuzz,topspeed
SWITCHBOARD_KILL_SWITCH=0                  # 1 halts all dispatch + live actions (observe still runs)
SWITCHBOARD_DRY_RUN_DEFAULT=1             # every action adapter defaults to dry-run

# ---- Governor spend caps (config, not code — PRD §8) ------------------------
CAP_AHREFS_UNITS_PER_DAY=5000
CAP_AHREFS_UNITS_PER_RUN=1000
CAP_LLM_MICROS_PER_DAY=20000000           # $20.00/day in micro-USD
CAP_LLM_MICROS_PER_RUN=5000000            # $5.00/run
CAP_BQ_BYTES_PER_DAY=107374182400         # 100 GiB/day scanned
CAP_BQ_BYTES_PER_RUN=21474836480          # 20 GiB/run

# ---- Shared memory (Postgres) ----------------------------------------------
DATABASE_URL=postgresql+asyncpg://switchboard:switchboard@localhost:5432/switchboard

# ---- LLM substrate ----------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-REPLACE          # one dashboard-owned key (PRD consolidation note)
MODEL_DEFAULT=claude-sonnet-4-6           # most agents  (keep model IDs in config, PRD §11)
MODEL_SYNTHESIS=claude-opus-4-5           # orchestrator planning + opportunity scouting
MODEL_FACTCHECK=claude-haiku-4-5          # cheap fact-gate verification

# ---- Auth: Google OAuth / OIDC (PRD §9.1) ----------------------------------
GOOGLE_OAUTH_CLIENT_ID=REPLACE.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=REPLACE
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8080/auth/callback
AUTH_ALLOWED_DOMAINS=valnetinc.com        # hd hint, verified server-side
AUTH_ALLOWLIST=andrew.marks@valnetinc.com # explicit user allowlist (comma-separated)
SESSION_SECRET=REPLACE                    # signs the Switchboard session cookie

# ---- Shared resource credentials (service accounts / app keys) --------------
# Sentinel Pro (Analytics / Paid-Media)
SENTINEL_API_KEY=REPLACE
SENTINEL_ACCOUNT=valnet
# Asana (Production) — shared Albert/Seona identity
ASANA_PAT=REPLACE
# BigQuery + Sheets service account (inline JSON or file path)
GOOGLE_SHEETS_SERVICE_ACCOUNT_JSON={"type":"service_account", "...": "..."}
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
BIGQUERY_PROJECT_ID=data-science-458422
# Ahrefs (Opportunity) — metered, see governor
AHREFS_API_KEY=REPLACE
# Similarweb (Research) — already used by daily-reporting-agent, reuse
SIMILARWEB_API_KEY=REPLACE

# ---- Gmail send (Reporting & Distribution) — gmail.send scope only ----------
GMAIL_CLIENT_ID=REPLACE.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=REPLACE
GMAIL_REFRESH_TOKEN=REPLACE
GMAIL_TOKEN_URI=https://oauth2.googleapis.com/token
GMAIL_SENDER=anthony.a@valnetinc.com

# ---- Paid-media ad platforms (read-only) ------------------------------------
GOOGLE_ADS_DEVELOPER_TOKEN=REPLACE
GOOGLE_ADS_CLIENT_ID=REPLACE
GOOGLE_ADS_CLIENT_SECRET=REPLACE
GOOGLE_ADS_REFRESH_TOKEN=REPLACE
GOOGLE_ADS_CUSTOMER_ID=REPLACE
FACEBOOK_ACCESS_TOKEN=REPLACE
FACEBOOK_AD_ACCOUNT_ID=act_REPLACE
BING_DEVELOPER_TOKEN=REPLACE
BING_CLIENT_ID=REPLACE
BING_CLIENT_SECRET=REPLACE
BING_REFRESH_TOKEN=REPLACE
BING_CUSTOMER_ID=REPLACE
BING_ACCOUNT_ID=REPLACE
GOOGLE_CAD_TO_USD_RATE=0.73
# Lead feeds
LOTLINX_CLIENT_ID=REPLACE
LOTLINX_CLIENT_SECRET=REPLACE
S3_ACCESS_KEY_ID=REPLACE
S3_SECRET_ACCESS_KEY=REPLACE
S3_BUCKET_NAME=valnet-quotewizard
S3_CARZING_ACCESS_KEY_ID=REPLACE
S3_CARZING_SECRET_ACCESS_KEY=REPLACE
S3_CARZING_BUCKET_NAME=valnet-carzing-mp
SPREADSHEET_ID=REPLACE                    # paid-media RAW_DATA sheet

# ---- Slack (notify only) ----------------------------------------------------
SLACK_BOT_TOKEN=xoxb-REPLACE
SLACK_CHANNEL_ID=REPLACE
SLACK_NOTIFY_ENABLED=0                    # 1 to actually post (otherwise log-only)
SLACK_CHANNEL_ID_TRENDS=                  # optional dedicated channel for trend-pipeline events
SWITCHBOARD_PUBLIC_URL=                   # console base URL used in Slack links (e.g. https://shellagent.io/agents/adam-abundance)

# ---- Competitor trend pipeline (docs/trend-pipeline.md) ----------------------
TREND_PIPELINE_ENABLED=1
TREND_SCAN_INTERVAL_MIN=120               # scheduler cadence for the scout
TREND_SCORE_THRESHOLD=60                  # propose a pipeline at/above this score (0-100)
TREND_MIN_SOURCES=2                       # distinct outlets before a cluster counts
TREND_MAX_OPEN_PIPELINES=5                # per brand — the scout stops proposing beyond this
TREND_TTL_HOURS=48                        # unactioned trends expire (breaking news is perishable)
TREND_DEDUP_DAYS=5                        # dismissed/declined clusters are not re-proposed within this
TREND_AUTO_DOSSIER=1                      # build the dossier when a trend is proposed
TREND_BASE_QUERY=automotive industry news # what the source APIs are asked for
TREND_WATCHLIST=                          # csv terms that boost scoring, e.g. tesla,ford f-150,recall
TREND_DEFAULT_CONTENT_TYPES=article,social_post
# per-content-type transport: llm | hc_viral_hits | social_api | newsletter_api | shellagent_run
TREND_TRANSPORT_ARTICLE=llm
TREND_TRANSPORT_SOCIAL_POST=llm
TREND_TRANSPORT_NEWSLETTER_BLURB=llm
TREND_TRANSPORT_VIDEO_SCRIPT=llm
# sourcing keys (all optional — adapters degrade softly when absent). Each is a
# trend-source the scout calls per scan; usage is counted in tool_call_log and
# shown on the dashboard Resource-usage panel.
TAVILY_API_KEY=REPLACE
PERPLEXITY_API_KEY=REPLACE
FIRECRAWL_API_KEY=REPLACE
NEWSAPI_API_KEY=REPLACE
YOUTUBE_API_KEY=REPLACE                   # YouTube Data API v3 (search = 100 quota units/call)
X_BEARER_TOKEN=REPLACE                    # X API v2 recent search (needs a paid tier)
X_CONSUMER_KEY=REPLACE
X_CONSUMER_SECRET=REPLACE
SEMRUSH_API_KEY=REPLACE                   # SEMrush Analytics API (units billed per call)
# service logos on the dashboard Resource-usage panel (publishable key pk_...);
# absent → a 2-letter monogram is shown instead
LOGO_DEV_TOKEN=
# generic ShellAgent generators (transport shellagent_run): POST {url}/run, Bearer token
TREND_AGENT_ARTICLE_URL=
TREND_AGENT_ARTICLE_TOKEN=
TREND_AGENT_SOCIAL_POST_URL=
TREND_AGENT_SOCIAL_POST_TOKEN=
# hc_viral_hits transport: session login for intake/publish + the machine API
# key for the CMS draft surface (same key the HC-Viral read adapter uses)
HC_VIRAL_HITS_API_KEY=REPLACE
HC_VIRAL_HITS_LOGIN_EMAIL=
HC_VIRAL_HITS_LOGIN_PASSWORD=
# our own news feeds for the coverage-gap check (defaults to https://www.<domain>/feed/)
OUR_NEWS_FEED_HOTCARS=
OUR_NEWS_FEED_CARBUZZ=
OUR_NEWS_FEED_TOPSPEED=

# ---- Per-brand identifiers (non-secret) -------------------------------------
SHEET_ID_HOTCARS=REPLACE
SHEET_ID_CARBUZZ=REPLACE
SHEET_ID_TOPSPEED=REPLACE

# ---- Existing-system endpoints Switchboard reads/triggers (non-secret) ------
ALBERT_API_URL=http://localhost:3100
SEONA_API_URL=http://localhost:3110
HC_VIRAL_HITS_API_URL=http://127.0.0.1:8001
WRITERS_DASHBOARD_URL=http://localhost:3107

# ---- Artifact store (GCS bucket or local dir fallback) ----------------------
ARTIFACT_STORE=local                      # local | gcs
ARTIFACT_GCS_BUCKET=switchboard-artifacts
ARTIFACT_LOCAL_DIR=./local_artifacts
