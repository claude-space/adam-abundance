# =============================================================================
# Switchboard — PRODUCTION env template for the ShellAgent VM.
# Copy to `.env` in the repo root on the VM and fill in. PM2 (ecosystem.config.js)
# loads this file and injects it into both processes. NEVER commit `.env`.
# Secrets may instead come from GCP Secret Manager (set SECRETS_MANAGER_PROJECT);
# env is the fallback. For manual CLI use outside PM2, prefix commands with
# `SWITCHBOARD_ENV_FILE=.env` so the credentials layer reads this file.
# =============================================================================

# ---- core ----
SWITCHBOARD_ENV=prod                      # disables the local dev-login; requires Google OAuth
PORT=3150                                 # SHA/PM2 convention (VM_PORT). settings reads PORT first, then SWITCHBOARD_PORT
APP_BASE_PATH=/agents/adam-abundance      # Caddy serves this app under /agents/<slug>/ (strip_prefix); links+redirects get prefixed
SWITCHBOARD_BRANDS=hotcars                # start single-brand; add carbuzz,topspeed when trusted
SWITCHBOARD_KILL_SWITCH=1                 # START LOCKED: observe+plan run, dispatch is halted. Flip to 0 to go live.
SWITCHBOARD_DRY_RUN_DEFAULT=1

# ---- spend caps: OFF for now (per your call) ----
SPEND_CAPS_ENABLED=0                      # governor won't refuse on budget; spend still metered + shown

# ---- workflow endpoint (POST /run, used by ShellAgent Workflows) ----
SWITCHBOARD_RUN_TOKEN=REPLACE_WITH_LONG_RANDOM_STRING   # bearer token; unset => /run returns 503. e.g. `openssl rand -hex 32`

# ---- database: Supabase (Session pooler, port 5432) ----
#   Supabase dashboard → Project Settings → Database → Connection string (URI, "Session pooler").
#   Convert postgresql:// -> postgresql+asyncpg://  and append ?ssl=require.
#   This project's pooler host/user are pre-filled; set <PASSWORD> to the DB password.
DATABASE_URL=postgresql+asyncpg://postgres.pyxekejzirlsmkrnvlhu:<PASSWORD>@aws-0-us-east-1.pooler.supabase.com:5432/postgres?ssl=require
DB_STATEMENT_CACHE_SIZE=0                 # asyncpg + Supabase pooler compatibility (keep set)

# ---- auth: Google OAuth (OIDC) ----
GOOGLE_OAUTH_CLIENT_ID=REPLACE.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=REPLACE
#   Caddy strip_prefix: the PUBLIC callback URL includes the /agents/<slug> prefix.
#   This must EXACTLY match the Authorized redirect URI in the Google console.
GOOGLE_OAUTH_REDIRECT_URI=https://YOUR-VM-HOST/agents/adam-abundance/auth/callback
AUTH_ALLOWED_DOMAINS=valnetinc.com
AUTH_ALLOWLIST=andrew.marks@valnetinc.com                       # comma-separated: who may sign in
AUTH_ADMINS=andrew.marks@valnetinc.com                          # bootstrapped to global_admin
AUTH_DEFAULT_ROLE=portfolio_admin                              # role for other allowlisted users
SESSION_SECRET=REPLACE_WITH_LONG_RANDOM_STRING                 # e.g. `openssl rand -hex 32`

# ---- LLM (consolidate to ONE dashboard-owned key; see switchboard.env rotation note) ----
ANTHROPIC_API_KEY=sk-ant-REPLACE
MODEL_DEFAULT=claude-sonnet-4-6
MODEL_SYNTHESIS=claude-opus-4-5
MODEL_FACTCHECK=claude-haiku-4-5

# ---- Slack: intentionally NOT configured (leave off; won't touch your channels) ----
# SLACK_NOTIFY_ENABLED stays unset/0 -> the morning brief is logged, never posted.

# ---- existing-system endpoints (same VM -> localhost) ----
ALBERT_API_URL=http://localhost:3100
SEONA_API_URL=http://localhost:3110
HC_VIRAL_HITS_API_URL=http://127.0.0.1:8001
WRITERS_DASHBOARD_URL=http://localhost:3001
CONTENT_AUDITOR_URL=http://localhost:8600
NEWSLETTER_API_URL=http://localhost:5200
SOCIAL_API_URL=http://localhost:3145
#   Action endpoint paths — confirm against the live apps before flipping to LIVE:
# ALBERT_IDEATE_PATH=/api/ideate
# ALBERT_ROUTE_PATH=/api/writer/route
# ALBERT_OUTLINE_PATH=/api/outline-review/status
# ALBERT_WRITER_PATH=/api/writer/queue
# SEONA_IDEATE_PATH=/api/ideate
# SEONA_DECAY_PATH=/api/decay/queue
# SEONA_DECAY_LIST_PATH=/api/decay/candidates
#   Asana GIDs (per brand) — needed for create_asana_task + outline reads:
# ASANA_PROJECT_HOTCARS=...
# ASANA_SECTION_OUTLINE_HOTCARS=...

# ---- artifacts ----
ARTIFACT_STORE=local                      # or gcs
ARTIFACT_LOCAL_DIR=/var/lib/switchboard/artifacts
# ARTIFACT_GCS_BUCKET=switchboard-artifacts

# ---- optional: GCP Secret Manager backend (recommended over plaintext env) ----
# SECRETS_MANAGER_PROJECT=data-science-458422

# =============================================================================
# RESOURCE CREDENTIALS (service accounts / app keys) — copy the working values
# from your existing switchboard.env: SENTINEL_API_KEY, ASANA_PAT, AHREFS_API_KEY,
# SIMILARWEB_API_KEY, GOOGLE_SHEETS_SERVICE_ACCOUNT_JSON (or GOOGLE_APPLICATION_CREDENTIALS),
# BIGQUERY_PROJECT_ID, GMAIL_* , GOOGLE_ADS_*/FACEBOOK_*/BING_*, LOTLINX_*, S3_*,
# HC_VIRAL_HITS_API_KEY, HC_VIRAL_HITS_EMAKI_STATE, SHEET_ID_*, SPREADSHEET_ID.
# These authenticate every tool call — never the logged-in user's token (§9.1).
# =============================================================================
